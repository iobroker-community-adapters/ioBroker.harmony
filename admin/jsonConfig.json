{
    "type": "panel",
    "i18n": true,
    "items": {
        "_discoveryHeader": {
            "type": "header",
            "text": "discoveryHeader",
            "size": 5
        },
        "_discoveryInfo": {
            "type": "staticText",
            "text": "discoveryInfo",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "style": {
                "fontSize": 14,
                "marginBottom": 16
            }
        },
        "networkInterface": {
            "type": "ip",
            "label": "networkInterfaceLabel",
            "tooltip": "networkInterfaceTooltip",
            "onlyIp4": true,
            "noInternal": true,
            "listenOnAllPorts": true,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "discoverInterval": {
            "type": "number",
            "label": "discoverIntervalLabel",
            "tooltip": "discoverIntervalTooltip",
            "unit": "ms",
            "default": 2000,
            "min": 500,
            "xs": 12,
            "sm": 12,
            "md": 6,
            "lg": 6,
            "xl": 6
        },
        "_devicesHeader": {
            "newLine": true,
            "type": "header",
            "text": "devicesHeader",
            "size": 5,
            "style": {
                "marginTop": 16
            }
        },
        "_devicesInfo": {
            "type": "staticText",
            "text": "devicesInfo",
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "style": {
                "fontSize": 14,
                "marginBottom": 8
            }
        },
        "devices": {
            "type": "table",
            "label": "devicesLabel",
            "useCardFor": ["xs"],
            "xs": 12,
            "sm": 12,
            "md": 12,
            "lg": 12,
            "xl": 12,
            "items": [
                {
                    "attr": "name",
                    "type": "text",
                    "label": "devicesNameLabel",
                    "width": "40%"
                },
                {
                    "attr": "ip",
                    "type": "text",
                    "label": "devicesIpLabel",
                    "width": "60%"
                }
            ]
        }
    }
}
